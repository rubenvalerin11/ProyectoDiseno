<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ProyectoDiseño</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light apple-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand apple-brand" href="@Url.Action("Index", "Home")">
                Proyecto Clientes
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal" aria-controls="menuPrincipal" aria-expanded="false" aria-label="Mostrar navegación">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                    <li class="nav-item">
                        <a class="nav-link apple-link" href="@Url.Action("Index", "Home")">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link apple-link" href="@Url.Action("Index", "ClientesPage")">Clientes</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link apple-link" href="@Url.Action("Index", "Calculadora")">Calculadora</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link apple-link" href="@Url.Action("Index", "Archivos")">Archivos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link apple-link" href="@Url.Action("Index", "Lecturas")">Lecturas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link apple-link" href="@Url.Action("Index", "Historial")">Historial</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="page-enter">
        @RenderBody()
        @RenderSection("Scripts", required: false)
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="~/js/navbar.js" asp-append-version="true"></script>
</body>
</html>