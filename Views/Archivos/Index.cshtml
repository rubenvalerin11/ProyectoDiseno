@{
    ViewData["Title"] = "Exportar Archivos";
}

<section class="py-5">
    <div class="container">
        <div class="card custom-card p-4">
            <h2 class="section-title mb-4">📤 Exportación de Datos de Clientes</h2>

            <p class="text-muted mb-4">Descarga los datos de clientes en los formatos que prefieras:</p>

            <div class="d-flex flex-wrap gap-3">
                <a href="/Clientes/ExportarJson" class="btn btn-success btn-pill px-4">
                    <i class="bi bi-download"></i> Exportar JSON
                </a>
                <a href="/Clientes/ExportarXml" class="btn btn-primary btn-pill px-4">
                    <i class="bi bi-download"></i> Exportar XML
                </a>
            </div>

            <hr class="my-5">

            <h3 class="section-title mb-4">📥 Importar Datos desde Archivos</h3>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Importar JSON</h5>
                            <form action="/Clientes/ImportarJson" method="post" enctype="multipart/form-data" class="d-flex gap-2">
                                <input type="file" name="archivo" accept=".json" required class="form-control" />
                                <button type="submit" class="btn btn-warning">Importar</button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Importar XML</h5>
                            <form action="/Clientes/ImportarXml" method="post" enctype="multipart/form-data" class="d-flex gap-2">
                                <input type="file" name="archivo" accept=".xml" required class="form-control" />
                                <button type="submit" class="btn btn-info">Importar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
