@{
    ViewData["Title"] = "Gestión de Clientes";
}

<section class="py-5">
    <div class="container">
        <div class="card custom-card p-4">
            <h2 class="section-title mb-4">✏️ Registrar Cliente</h2>

            <div class="row g-3"> 
                <div class="col-md-3">
                    <input type="text" id="txtCedula" class="form-control form-control-lg" placeholder="Cédula" />
                </div>
                <div class="col-md-3">
                    <input type="text" id="txtNombre" class="form-control form-control-lg" placeholder="Nombre" />
                </div>
                <div class="col-md-3">
                    <input type="text" id="txtApellido1" class="form-control form-control-lg" placeholder="Apellido 1" />
                </div>
                <div class="col-md-3">
                    <input type="text" id="txtApellido2" class="form-control form-control-lg" placeholder="Apellido 2" />
                </div>
            </div>

            <div class="mt-4">
                <button class="btn btn-dark btn-pill px-4" onclick="guardarCliente()">
                    Guardar cliente
                </button>

                <div id="mensajeCliente" class="mt-3 fw-semibold"></div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-soft">
    <div class="container">
        <div class="card custom-card p-4">
            <h2 class="section-title mb-4">📋 Clientes Registrados</h2>

            <div class="table-responsive">
                <table class="table table-hover align-middle table-modern" id="tablaClientes">
                    <thead>
                        <tr>
                            <th>Cédula</th>
                            <th>Nombre</th>
                            <th>Apellido 1</th>
                            <th>Apellido 2</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function guardarCliente() {
            const cliente = {
                cedula: document.getElementById("txtCedula").value.trim(),
                nombre: document.getElementById("txtNombre").value.trim(),
                apellido1: document.getElementById("txtApellido1").value.trim(),
                apellido2: document.getElementById("txtApellido2").value.trim()
            };

            if (!cliente.cedula || !cliente.nombre || !cliente.apellido1 || !cliente.apellido2) {
                mostrarMensaje("Complete todos los campos", "danger");
                return;
            }

            fetch("/ClientesPage/Insertar", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(cliente)
            })
            .then(response => response.json())
            .then(data => {
                if (data.ok) {
                    mostrarMensaje(data.mensaje, "success");
                    document.getElementById("txtCedula").value = "";
                    document.getElementById("txtNombre").value = "";
                    document.getElementById("txtApellido1").value = "";
                    document.getElementById("txtApellido2").value = "";
                    cargarClientes();
                } else {
                    mostrarMensaje(data.mensaje, "danger");
                }
            })
            .catch(error => {
                console.error("Error:", error);
                mostrarMensaje("Error al guardar cliente", "danger");
            });
        }

        function cargarClientes() {
            fetch("/ClientesPage/ObtenerTodos")
            .then(response => response.json())
            .then(data => {
                const tbody = document.querySelector("#tablaClientes tbody");
                tbody.innerHTML = "";

                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">No hay clientes registrados</td></tr>';
                    return;
                }

                data.forEach(c => {
                    const fila = `
                        <tr>
                            <td><strong>${c.cedula}</strong></td>
                            <td>${c.nombre}</td>
                            <td>${c.apellido1}</td>
                            <td>${c.apellido2}</td>
                        </tr>
                    `;
                    tbody.innerHTML += fila;
                });
            })
            .catch(error => console.error("Error al cargar clientes:", error));
        }

        function mostrarMensaje(mensaje, tipo) {
            const div = document.getElementById("mensajeCliente");
            div.className = `alert alert-${tipo}`;
            div.textContent = mensaje;
            setTimeout(() => {
                div.className = "";
                div.textContent = "";
            }, 4000);
        }

        document.addEventListener("DOMContentLoaded", cargarClientes);
    </script>
}
